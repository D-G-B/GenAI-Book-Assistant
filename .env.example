# Copy to .env and fill in. .env is gitignored; this template is checked in.

# ─────────────────────────────────────────────────────────────────────────────
# LLM providers (set at least one key + its matching model). Fallback order is
# Google → OpenAI → Anthropic. A key without its DEFAULT_*_MODEL is skipped.
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=
DEFAULT_GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
DEFAULT_OPENAI_MODEL=gpt-4o-mini
# Optional: point OpenAI client at a compatible gateway (e.g. GitHub Models PAT).
OPENAI_BASE_URL=

ANTHROPIC_API_KEY=
DEFAULT_CLAUDE_MODEL=claude-3-5-sonnet-latest

# ─────────────────────────────────────────────────────────────────────────────
# Auth / session (Increment 2 — Google OAuth + signed-cookie session)
# ─────────────────────────────────────────────────────────────────────────────
# Signs the session cookie. REQUIRED: the app refuses to start with an unset/
# default secret unless DEBUG=true or DEV_AUTH_BYPASS=true. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=

# Add the Secure flag to the session cookie. Leave false for local http dev;
# set true wherever the app is served over HTTPS.
SESSION_COOKIE_SECURE=false

# Google OAuth 2.0 credentials. Create at https://console.cloud.google.com:
#   1. APIs & Services → OAuth consent screen (External; add your email as a test user).
#   2. APIs & Services → Credentials → Create OAuth client ID → Web application.
#   3. Authorized redirect URI:  http://localhost:8000/auth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Local-dev escape hatch: when true, requests with no logged-in session fall back
# to the fixed dev user instead of 401 — lets you run the app before Google is set
# up. Leave false (or unset) in any real deployment.
DEV_AUTH_BYPASS=false

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
# Default is local SQLite. Switch to Postgres in production (Phase 2 item 3).
DATABASE_URL=sqlite:///./app.db

# ─────────────────────────────────────────────────────────────────────────────
# App / logging
# ─────────────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
MAX_TOKENS=1000

# Input limits
MAX_UPLOAD_SIZE_MB=50
MAX_QUESTION_LENGTH=2000

# ─────────────────────────────────────────────────────────────────────────────
# Retrieval
# ─────────────────────────────────────────────────────────────────────────────
RETRIEVAL_K=8
LLM_REQUEST_TIMEOUT=30
LLM_MAX_RETRIES=2

# Cross-encoder reranker (set RERANKER_ENABLED=false on low-memory machines)
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-base
RERANK_POOL_SIZE=30

# Hybrid LLM chapter detection at ingest (regex anchors + one labelling call).
# 16000 default: gemini-2.5-flash is a thinking model whose reasoning eats the
# output budget, so labelling JSON truncates below ~16k. Raise for very large books.
LLM_CHAPTER_DETECTION_ENABLED=true
LLM_CHAPTER_DETECTION_MAX_TOKENS=16000
